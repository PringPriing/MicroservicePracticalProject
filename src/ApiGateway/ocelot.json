{
  "Routes": [
    {
      "UpstreamPathTemplate": "/auth/{everything}",
      "DownstreamPathTemplate": "/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "usermanagement-api", "Port": 8081 }
      ],
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    },
    {
      "UpstreamPathTemplate": "/products",
      "DownstreamPathTemplate": "/products",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "productcatalog-api", "Port": 8082 }
      ],
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    },
    {
      "UpstreamPathTemplate": "/products/{everything}",
      "DownstreamPathTemplate": "/products/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "productcatalog-api", "Port": 8082 }
      ],
      "UpstreamHttpMethod": [ "GET" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    },
    {
      "UpstreamPathTemplate": "/categories",
      "DownstreamPathTemplate": "/categories",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "productcatalog-api", "Port": 8082 }
      ],
      "UpstreamHttpMethod": [ "POST" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    },
    {
      "UpstreamPathTemplate": "/cart/{everything}",
      "DownstreamPathTemplate": "/cart/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "productcatalog-api", "Port": 8082 }
      ],
      "UpstreamHttpMethod": [ "POST" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    },
    {
      "UpstreamPathTemplate": "/inventory/{everything}",
      "DownstreamPathTemplate": "/inventory/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "productcatalog-api", "Port": 8082 }
      ],
      "UpstreamHttpMethod": [ "PUT" ],
      "LoadBalancerOptions": { "Type": "RoundRobin" }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://api-gateway:8080"
  }
}
